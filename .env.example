# -- PostgreSQL (used by Docker Compose and DATABASE_URL) --
POSTGRES_USER=ontosphere
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ontosphere

# -- Database --
DATABASE_URL=postgresql+asyncpg://ontosphere:changeme@postgres:5432/ontosphere

# -- Redis / Celery --
REDIS_URL=redis://redis:6379/0

# -- LLM --
ONTOSPHERE_LLM_PROVIDER=azure
ONTOSPHERE_LLM_API_BASE=https://YOUR-RESOURCE.openai.azure.com
ONTOSPHERE_LLM_API_KEY=your-key-here
ONTOSPHERE_LLM_MODEL=gpt-4o
ONTOSPHERE_LLM_API_VERSION=2024-10-21
ONTOSPHERE_LLM_MAX_TOKENS=16384

# -- Security --
SECRET_KEY=change-me-in-production

# -- CORS (comma-separated or JSON array) --
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -- Auto table creation (set to false once you use Alembic migrations) --
ONTOSPHERE_AUTO_CREATE_TABLES=true

# -- Frontend (used by Docker Compose; ignored by backend) --
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_WS_BASE_URL=ws://localhost:8000
